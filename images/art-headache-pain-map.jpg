1":"headache","sideEffectsWidget":{},"livedExperience":{},"shareYourExperience":{},"drugSavingsData":null,"comments":[],"topComments":[],"id":"mnt-3431412","title":["Types of headache by location and symptoms"],"articleHistory":{"2021-10-29":{"updateReason":[],"authors":"Sasha Santhakumar","editor":"MNT Demand Team","copyEditor":"Gianna D'Emilio","medicallyReviewedBy":"Deena Kuruvilla, MD"},"2023-10-10":{"updateReason":["The article was updated with additional information to ensure it provides our readers with a comprehensive overview of the topic."],"authors":"Sasha Santhakumar","editor":"MNT Demand Team"},"2024-08-09":{"updateReason":["The article was updated with additional information to ensure it provides our readers with a comprehensive overview of the topic.","The article was updated with current verified sources and links to relevant information."],"authors":"Sasha Santhakumar","editor":"Chloe Szilagyi","copyEditor":"Copy Editors","medicallyReviewedBy":"Heidi Moawad, MD"}},"updateReason":["The article was updated with additional information to ensure it provides our readers with a comprehensive overview of the topic.","The article was updated with current verified sources and links to relevant information."],"isFeature":false,"isPaidMedia":false,"isEditorialPaidMedia":false,"isTransactionalPaidMedia":false,"isMarketingLandingPage":false,"mktglpColorTheme":"","authors":[{"id":4026,"name":{"display":"Sasha Santhakumar","first":"Sasha","last":"Santhakumar"},"type":{"value":"author","label":"Author"},"nid":"","specialties":[],"guestTitle":"","bio":{"text":""},"avatar":{"title":"","src":"","alt":""}}],"medicalReviewers":[{"id":333,"name":{"display":"Heidi Moawad, M.D.","first":"Heidi","last":"Moawad, MD"},"userLogin":"heidimoawad","links":{"website":"http://www.nonclinicaldoctors.com/","facebook":"","linkedin":"https://www.linkedin.com/in/heidi-moawad-md-17879aa/","twitter":"","instagram":"","tiktok":""},"link":"/reviewers/heidi-moawad-md","type":{"value":"medical_reviewer","label":"Medical Advisor"},"nid":"159928","specialties":[],"guestTitle":"","bio":{"text":"\u003cspan style=\"font-weight: 400;\"\u003eDr. Heidi Moawad is a neurologist and teaches at Case Western Reserve University School of Medicine in Cleveland, Ohio. She serves on the editorial board of Neurology Clinical Practice and is a reviewer for Neurology.\u003c/span\u003e\r\n\r\n\u003cstrong\u003eEducation\u003c/strong\u003e\r\n\u003cul\u003e\r\n \t\u003cli style=\"font-weight: 400;\"\u003e\u003cspan style=\"font-weight: 400;\"\u003eCase Western Reserve University School of Medicine, MD\u003c/span\u003e\u003c/li\u003e\r\n\u003c/ul\u003e\r\n\u003cstrong\u003eCertifications\u003c/strong\u003e\r\n\u003cul\u003e\r\n \t\u003cli style=\"font-weight: 400;\"\u003e\u003cspan style=\"font-weight: 400;\"\u003eBoard of Medical Examiners\u003c/span\u003e\u003c/li\u003e\r\n\u003c/ul\u003e\r\n\u003cstrong\u003eProfessional Accomplishments\u003c/strong\u003e\r\n\u003cul\u003e\r\n \t\u003cli style=\"font-weight: 400;\"\u003e\u003cspan style=\"font-weight: 400;\"\u003eAssociate editor, Neurology, Humanities section \u003c/span\u003e\u003c/li\u003e\r\n \t\u003cli style=\"font-weight: 400;\"\u003e\u003cspan style=\"font-weight: 400;\"\u003ePast editor-in-chief of Neurology Times\u003c/span\u003e\u003c/li\u003e\r\n\u003c/ul\u003e\r\n\u003cstrong\u003eAffiliations\u003c/strong\u003e\r\n\u003cul\u003e\r\n \t\u003cli style=\"font-weight: 400;\"\u003e\u003ca href=\"https://www.aan.com/\"\u003e\u003cspan style=\"font-weight: 400;\"\u003eAmerican Academy of Neurology (AAN)\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\r\n\u003c/ul\u003e"},"avatar":{"title":"","width":500,"height":500,"src":"https://post.medicalnewstoday.com/wp-content/uploads/2022/01/Heidi-Moawad-500x500-Bio.png","alt":""},"bioBlurb":{"nodes":["Dr. Heidi Moawad is a neurologist and teaches at Case Western Reserve University School of Medicine in Cleveland, Ohio. She serves on the editorial board of…"]}}],"editors":[{"role":"Editor","name":{"display":"Chloe Szilagyi"}}],"pinterestImage":{"path":"https://media.post.rvohealth.io/wp-content/uploads/sites/3/2021/07/headache_types_Stocksy_3751474_Thumb.jpg"},"hideFeedback":false,"isMedicare":false,"isBlog":false,"publishSource":"wordpress","isAmpSupported":false,"categories":[{"name":"Headache / Migraine","slug":"headache-migraine","link":"/categories/headache-migraine","primary":true,"children":[]},{"name":"Neurology / Neuroscience","slug":"neurology","link":"/categories/neurology","children":[]},{"name":"Pain / Anesthetics","slug":"pain","link":"/categories/pain","children":[]}],"language":{"current":"en","default":"en","language_data":{"en":{"id":3431412,"root_id":1068298},"x-default":{"id":3431412,"root_id":1068298}},"en":"https://www.medicalnewstoday.com/articles/headache-chart/","x-default":"https://www.medicalnewstoday.com/articles/headache-chart/"},"lang":"en","links":[{"rel":"alternate","hrefLang":"default","href":"en"},{"rel":"alternate","hrefLang":"language_data","href":{"en":{"id":3431412,"root_id":1068298},"x-default":{"id":3431412,"root_id":1068298}}},{"rel":"alternate","hrefLang":"en","href":"https://www.medicalnewstoday.com/articles/headache-chart/"},{"rel":"alternate","hrefLang":"x-default","href":"https://www.medicalnewstoday.com/articles/headache-chart/"}],"colorScheme":"default","isContentSeries":false,"brandCTAs":[],"treatmentComparison":{"items":[],"features":[]},"clusterNavV2":null,"clusterLinks":{},"pathingTilesData":{},"pathingCardsData":{},"inArticlePathingCardsData":[],"quantitativeTrustData":{},"isPrependRecipeH2":false,"isRecipeRoundup":false,"recipes":[],"breadcrumbsV2":[],"hideTabs":false,"tabs":[{"id":"_noHeaderPrefixedContent","title":null,"header":null,"body":[{"tagName":"div","source":"\u003cp class=\"css-2o7f22\"\u003eDifferent types of headaches can cause various symptoms and are typically located in different parts of the head. For instance, cluster headaches often occur behind or around one eye, and migraine typically occurs only on one side. \u003c/p\u003e"},{"tagName":"p","source":"There are many types of headache, and they may require professional care. Sometimes, this is because they stem from an underlying health condition. Nonetheless, medical care can help alleviate the pain even when no underlying condition is present. "},{"tagName":"div","attributes":{"data-preamp":"serena-chatbot"},"source":""},{"tagName":"p","source":"Below, learn about the different types of headaches, including their causes and other symptoms."}]},{"id":"overview","title":"Overview","isCollapsable":false,"header":["Headaches overview and chart"],"body":[{"tagName":"div","source":"\u003cfigure class=\"css-r55aa6\"\u003e\u003cspan class=\"css-rwmw5v\"\u003e\u003cspan class=\"css-1yf1yqk\"\u003e\u003cpicture class=\"css-1xfguvh\"\u003e\u003csource srcSet=\"//i0.wp.com/post.medicalnewstoday.com/wp-content/uploads/sites/3/2021/07/headache-location-infographic-1296x1296-body-897x1024.jpg?w=1575 750w\" media=\"(min-width: 1190px)\"/\u003e\u003csource srcSet=\"//i0.wp.com/post.medicalnewstoday.com/wp-content/uploads/sites/3/2021/07/headache-location-infographic-1296x1296-body-897x1024.jpg?w=1575 750w\" media=\"(min-width: 990px)\"/\u003e\u003csource srcSet=\"//i0.wp.com/post.medicalnewstoday.com/wp-content/uploads/sites/3/2021/07/headache-location-infographic-1296x1296-body-897x1024.jpg?w=1845 879w\" media=\"(min-width: 768px)\"/\u003e\u003cimg loading=\"eager\" src=\"//i0.wp.com/post.medicalnewstoday.com/wp-content/uploads/sites/3/2021/07/headache-location-infographic-1296x1296-body-897x1024.jpg?w=1155\u0026h=3110\" alt=\"Infographic showing the locations of different headache types\" class=\"css-1jytyml\"/\u003e\u003c/picture\u003e\u003c/span\u003e\u003chl-share-overlay class=\"css-1mqo1cs\"\u003e\u003ca class=\"icon-hl-pinterest css-v6xz9i\" target=\"_blank\" rel=\"noopener noreferrer nofollow\" data-event=\"Any Page|Image Pinterest Click|Icon Clicked\" data-element-event=\"OPEN|CONTENTBLOCK|Any Page|Article Body|BUTTON|Image Widget Pinterest Click|\" href=\"https://www.pinterest.com/pin/create/button/?url=https%3A%2F%2Fwww.medicalnewstoday.com%2Farticles%2Fheadache-chart\u0026media=https%3A%2F%2Fpost.medicalnewstoday.com%2Fwp-content%2Fuploads%2Fsites%2F3%2F2021%2F07%2Fheadache-location-infographic-1296x1296-body-897x1024.jpg\u0026description=Headache%20chart%3A%20Types%20by%20symptoms%2C%20location%2C%20and%20causes\" title=\"Share on Pinterest\" data-pin-custom=\"true\" data-share-url=\"https://post.medicalnewstoday.com/wp-content/uploads/sites/3/2021/07/headache-location-infographic-1296x1296-body-897x1024.jpg\"\u003e\u003cspan class=\"css-z1zfa\"\u003eShare on Pinterest\u003c/span\u003e\u003c/a\u003e\u003c/hl-share-overlay\u003e\u003c/span\u003e\u003cfigcaption class=\"css-1nzy6lj css-whkgel\"\u003eInfographic by Diego Sabogal\u003c/figcaption\u003e\u003c/figure\u003e"},{"tagName":"p","source":"According to the World Health Organization (WHO), \u003chl-trusted-source source=\"World Health Organization\" rationale=\"Highly respected international organization\"\u003e\u003ca href=\"https://www.who.int/news-room/fact-sheets/detail/headache-disorders\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003ealmost half\u003c/a\u003e\u003c/hl-trusted-source\u003e of all adults experience a \u003ca href=\"https://www.medicalnewstoday.com/articles/headaches\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/headaches\" class=\"content-link css-90fpmc\"\u003eheadache\u003c/a\u003e at least once a year."},{"tagName":"p","source":"A headache results from \u003ca href=\"https://www.medicalnewstoday.com/articles/248423\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/248423\" class=\"content-link css-90fpmc\"\u003einflammation\u003c/a\u003e in pain-sensitive parts of the head and neck. These areas \u003chl-trusted-source source=\"National Institute of Neurological Disorders and Stroke\" rationale=\"Governmental authority\"\u003e\u003ca href=\"https://www.ninds.nih.gov/health-information/disorders/headache\" data-type=\"link\" data-id=\"https://www.ninds.nih.gov/health-information/disorders/headache\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003einclude\u003c/a\u003e\u003c/hl-trusted-source\u003e the following:"},{"tagName":"ul","source":"\u003cli\u003enerves\u003c/li\u003e\u003cli\u003emuscles\u003c/li\u003e\u003cli\u003eblood vessels\u003c/li\u003e"},{"tagName":"p","source":"The International Headache Society classifies \u003ca href=\"https://ihs-headache.org/wp-content/uploads/2020/05/ICHD-3-Pocket-version.pdf\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003emore than 150\u003c/a\u003e types of headaches. More broadly, doctors recognize two categories: primary and secondary headaches."},{"tagName":"p","source":"When someone has a primary headache, the headache itself is the main concern — it is not a symptom of an underlying problem. A secondary headache results from a different health issue."},{"tagName":"p","source":"Symptoms of primary and secondary headaches can be similar, and a doctor can diagnose the headache type."}]},{"id":"tension-headaches","title":"Tension headaches","isCollapsable":false,"header":["Tension headaches"],"body":[{"tagName":"p","source":"These are sometimes called “tension-type” headaches. They result from muscle tension in the shoulders, neck, scalp, or jaw. \u003cbr\u003e\u003cbr\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/313020\" class=\"content-link css-90fpmc\"\u003eTension headaches\u003c/a\u003e are one of the \u003chl-trusted-source source=\"PubMed Central\" rationale=\"Highly respected database from the National Institutes of Health\"\u003e\u003ca href=\"https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10360340/\" data-type=\"link\" data-id=\"https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10360340/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003emost common\u003c/a\u003e\u003c/hl-trusted-source\u003e types of primary headaches. Globally, \u003chl-trusted-source source=\"PubMed Central\" rationale=\"Highly respected database from the National Institutes of Health\"\u003e\u003ca href=\"https://pubmed.ncbi.nlm.nih.gov/34128449/\" data-type=\"link\" data-id=\"https://pubmed.ncbi.nlm.nih.gov/34128449/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003eup to 78%\u003c/a\u003e\u003c/hl-trusted-source\u003e of people experience one at some point. They \u003chl-trusted-source source=\"World Health Organization\" rationale=\"Highly respected international organization\"\u003e\u003ca href=\"https://www.who.int/news-room/fact-sheets/detail/headache-disorders\" data-type=\"link\" data-id=\"https://www.who.int/news-room/fact-sheets/detail/headache-disorders\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003eoften start\u003c/a\u003e\u003c/hl-trusted-source\u003e during a person’s teenage years. "},{"tagName":"h3","source":"Symptoms and location"},{"tagName":"p","source":"Tension headaches \u003chl-trusted-source source=\"PubMed Central\" rationale=\"Highly respected database from the National Institutes of Health\"\u003e\u003ca href=\"https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10360340/\" data-type=\"link\" data-id=\"https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10360340/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003etypically involve\u003c/a\u003e\u003c/hl-trusted-source\u003e a pressing, dull pain. People sometimes refer to these as “hatband” headaches because the pain typically occurs around the back of the head, the temples, and the forehead, almost as if a tight hat is squeezing the head."},{"tagName":"p","source":"The pain is usually \u003ca href=\"https://americanmigrainefoundation.org/resource-library/tension-type-headache/\" data-type=\"link\" data-id=\"https://americanmigrainefoundation.org/resource-library/tension-type-headache/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003emild to moderate\u003c/a\u003e but not severe. It often comes on without warning and can last from 30 minutes to several days."},{"tagName":"p","source":"Tension-type headaches may trigger a migraine attack in people with a history of migraine."},{"tagName":"h3","source":"Causes"},{"tagName":"p","source":"\u003chl-trusted-source source=\"PubMed Central\" rationale=\"Highly respected database from the National Institutes of Health\"\u003e\u003ca href=\"https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10360340/\" data-type=\"link\" data-id=\"https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10360340/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003eResearchers\u003c/a\u003e\u003c/hl-trusted-source\u003e believe that tension headaches may occur in response to both genetic and environmental factors."},{"tagName":"p","source":"The most common cause is stress. Other possible causes include:"},{"tagName":"ul","source":"\u003cli\u003ea lack of sleep\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/8933\" class=\"content-link css-90fpmc\"\u003edepression\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/323454\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/323454\" class=\"content-link css-90fpmc\"\u003eanxiety\u003c/a\u003e\u003c/li\u003e"}]},{"id":"migraine","title":"Migraine","isCollapsable":false,"header":["Migraine"],"body":[{"tagName":"p","source":"\u003ca href=\"https://www.medicalnewstoday.com/articles/148373\" class=\"content-link css-90fpmc\"\u003eMigraine\u003c/a\u003e affects approximately \u003ca href=\"https://americanmigrainefoundation.org/migraine-101/\" data-type=\"link\" data-id=\"https://americanmigrainefoundation.org/migraine-101/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003e1 billion\u003c/a\u003e people worldwide. It can cause a \u003chl-trusted-source source=\"National Institute of Neurological Disorders and Stroke\" rationale=\"Governmental authority\"\u003e\u003ca href=\"https://www.ninds.nih.gov/health-information/disorders/migraine\" data-type=\"link\" data-id=\"https://www.ninds.nih.gov/health-information/disorders/migraine\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003emoderate to severe\u003c/a\u003e\u003c/hl-trusted-source\u003e primary headache that typically occurs on one side of the head. The pain and other symptoms can keep a person from doing their daily activities."},{"tagName":"p","source":"Migraine is more common among females than males. According to a 2021 report from the \u003chl-trusted-source source=\"Centers for Disease Control and Prevention (CDC)\" rationale=\"Governmental authority\"\u003e\u003ca href=\"https://www.cdc.gov/mmwr/volumes/72/wr/mm7222a6.htm\" data-type=\"link\" data-id=\"https://www.cdc.gov/mmwr/volumes/72/wr/mm7222a6.htm\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003eCenters for Disease Control and Prevention (CDC)\u003c/a\u003e\u003c/hl-trusted-source\u003e, women were almost three times more likely than men to have been bothered by a headache or migraine in the past 3 months."},{"tagName":"h3","source":"Symptoms and location"},{"tagName":"p","source":"During a migraine episode, a person may have moderate to severe throbbing or pulsing pain on one side of the head. The pain may last \u003chl-trusted-source source=\"National Institute of Neurological Disorders and Stroke\" rationale=\"Governmental authority\"\u003e\u003ca href=\"https://www.ninds.nih.gov/health-information/disorders/migraine\" data-type=\"link\" data-id=\"https://www.ninds.nih.gov/health-information/disorders/migraine\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003e4–72 hours\u003c/a\u003e\u003c/hl-trusted-source\u003e and worsen with physical activity."},{"tagName":"p","source":"Some people experience \u003ca href=\"https://www.medicalnewstoday.com/articles/326591\" class=\"content-link css-90fpmc\"\u003emigraine with aura\u003c/a\u003e. An aura is a set of sensory symptoms, which \u003chl-trusted-source source=\"PubMed Central\" rationale=\"Highly respected database from the National Institutes of Health\"\u003e\u003ca href=\"https://www.ncbi.nlm.nih.gov/books/NBK554611/\" data-type=\"link\" data-id=\"https://www.ncbi.nlm.nih.gov/books/NBK554611/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003emay include\u003c/a\u003e\u003c/hl-trusted-source\u003e: "},{"tagName":"ul","source":"\u003cli\u003eseeing bright or flashing lights\u003c/li\u003e\u003cli\u003eseeing geometric patterns\u003c/li\u003e\u003cli\u003ehaving \u003ca href=\"https://www.medicalnewstoday.com/articles/auditory-hallucinations\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/auditory-hallucinations\" class=\"content-link css-90fpmc\"\u003eauditory hallucinations\u003c/a\u003e\u003c/li\u003e\u003cli\u003ehaving numbness or tingling sensations\u003c/li\u003e"},{"tagName":"p","source":"Other symptoms of migraine \u003chl-trusted-source source=\"National Institute of Neurological Disorders and Stroke\" rationale=\"Governmental authority\"\u003e\u003ca href=\"https://www.ninds.nih.gov/health-information/disorders/migraine\" data-type=\"link\" data-id=\"https://www.ninds.nih.gov/health-information/disorders/migraine\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003ecan include\u003c/a\u003e\u003c/hl-trusted-source\u003e:"},{"tagName":"ul","source":"\u003cli\u003esensitivity to light, sounds, and smells\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/269511\" class=\"content-link css-90fpmc\"\u003enausea and vomiting\u003c/a\u003e\u003c/li\u003e\u003cli\u003eweakness\u003c/li\u003e\u003cli\u003eunexplained mood changes\u003c/li\u003e"},{"tagName":"h3","source":"Causes"},{"tagName":"p","source":"Migraine is thought to have a genetic cause since the condition \u003chl-trusted-source source=\"National Institute of Neurological Disorders and Stroke\" rationale=\"Governmental authority\"\u003e\u003ca href=\"https://www.ninds.nih.gov/health-information/disorders/migraine\" data-type=\"link\" data-id=\"https://www.ninds.nih.gov/health-information/disorders/migraine\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003etends to\u003c/a\u003e\u003c/hl-trusted-source\u003e run in families. "},{"tagName":"p","source":"Other factors that could trigger it include:"},{"tagName":"ul","source":"\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/145855\" class=\"content-link css-90fpmc\"\u003estress\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/323454\" class=\"content-link css-90fpmc\"\u003eanxiety\u003c/a\u003e\u003c/li\u003e\u003cli\u003ehormonal changes\u003c/li\u003e\u003cli\u003ebright or flashing lights\u003c/li\u003e\u003cli\u003etobacco use\u003c/li\u003e\u003cli\u003esleeping too much or \u003ca href=\"https://www.medicalnewstoday.com/articles/307334\" class=\"content-link css-90fpmc\"\u003etoo little\u003c/a\u003e\u003c/li\u003e\u003cli\u003estrong smells\u003c/li\u003e\u003cli\u003ecertain foods, \u003ca href=\"https://www.uhsussex.nhs.uk/resources/dietary-advice-for-migraine-2/\" data-type=\"link\" data-id=\"https://www.uhsussex.nhs.uk/resources/dietary-advice-for-migraine-2/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003esuch as\u003c/a\u003e:\u003cul\u003e\u003cli\u003echocolate\u003c/li\u003e\u003c/ul\u003e\u003cul\u003e\u003cli\u003ematured cheeses\u003c/li\u003e\u003cli\u003eprocessed meats\u003c/li\u003e\u003c/ul\u003e\u003c/li\u003e"}]},{"id":"cluster-headache","title":"Cluster headache","isCollapsable":false,"header":["Cluster headache"],"body":[{"tagName":"p","source":"\u003ca href=\"https://www.medicalnewstoday.com/articles/172387\" class=\"content-link css-90fpmc\"\u003eCluster headaches\u003c/a\u003e are a less common type of primary headache, affecting fewer than \u003chl-trusted-source source=\"World Health Organization\" rationale=\"Highly respected international organization\"\u003e\u003ca href=\"https://www.who.int/news-room/fact-sheets/detail/headache-disorders\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003e1 in 1,000\u003c/a\u003e\u003c/hl-trusted-source\u003e adults, as the WHO reports. \u003cbr\u003e\u003cbr\u003eThe organization also notes that these headaches are more common in men than women and typically develop in or after a person’s 20s."},{"tagName":"h3","source":"Symptoms and location"},{"tagName":"p","source":"Cluster headaches are recurring, brief headaches, typically focused in or around one eye. The pain tends to be severe and may last between \u003ca href=\"https://migrainetrust.org/understand-migraine/types-of-migraine/other-headache-disorders/cluster-headache/\" data-type=\"link\" data-id=\"https://migrainetrust.org/understand-migraine/types-of-migraine/other-headache-disorders/cluster-headache/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003e15 minutes and 3 hours\u003c/a\u003e. It usually occurs at night."},{"tagName":"p","source":"Cluster headaches can be episodic or chronic. Episodic cluster headaches occur repeatedly over 2 weeks to 3 months. A person may not have another for months or years. "},{"tagName":"p","source":"Chronic cluster headaches persist for more than a year without a remission — or with a remission shorter than 3 months."},{"tagName":"p","source":"Other symptoms of cluster headaches include:"},{"tagName":"ul","source":"\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/313606\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/313606\" class=\"content-link css-90fpmc\"\u003eeye redness\u003c/a\u003e or watering\u003c/li\u003e\u003cli\u003edrooping or \u003ca href=\"https://www.medicalnewstoday.com/articles/318219\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/318219\" class=\"content-link css-90fpmc\"\u003eswelling of the eyelid\u003c/a\u003e\u003c/li\u003e\u003cli\u003ereduced pupil size in one eye\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/excessive-face-and-head-sweating\" class=\"content-link css-90fpmc\"\u003efacial sweating\u003c/a\u003e\u003c/li\u003e\u003cli\u003ea runny or \u003ca href=\"https://www.medicalnewstoday.com/articles/nasal-congestion\" class=\"content-link css-90fpmc\"\u003eblocked nose\u003c/a\u003e\u003c/li\u003e\u003cli\u003erestlessness\u003c/li\u003e"},{"tagName":"p","source":"Up to \u003chl-trusted-source source=\"PubMed Central\" rationale=\"Highly respected database from the National Institutes of Health\"\u003e\u003ca href=\"https://www.ncbi.nlm.nih.gov/books/NBK544241/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003e33%\u003c/a\u003e\u003c/hl-trusted-source\u003e of people with cluster headaches may also experience nerve pain."},{"tagName":"h3","source":"Causes"},{"tagName":"p","source":"The cause of cluster headaches is not yet clear. However, they \u003ca href=\"https://migrainetrust.org/understand-migraine/types-of-migraine/other-headache-disorders/cluster-headache/\" data-type=\"link\" data-id=\"https://migrainetrust.org/understand-migraine/types-of-migraine/other-headache-disorders/cluster-headache/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003emay result\u003c/a\u003e from dysfunction in a part of the brain called the \u003ca href=\"https://www.medicalnewstoday.com/articles/312628\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/312628\" class=\"content-link css-90fpmc\"\u003ehypothalamus\u003c/a\u003e, which is involved in several physical functions."},{"tagName":"p","source":"Cluster headaches often develop in people who smoke."}]},{"id":"medication-overuse-headache","title":"Medication-overuse headache","isCollapsable":false,"header":["Medication overuse headache"],"body":[{"tagName":"p","source":"This is also called a rebound headache, and it is the \u003chl-trusted-source source=\"World Health Organization\" rationale=\"Highly respected international organization\"\u003e\u003ca href=\"https://www.who.int/news-room/fact-sheets/detail/headache-disorders\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003emost common\u003c/a\u003e\u003c/hl-trusted-source\u003e type of secondary headache. "},{"tagName":"p","source":"A medication overuse headache results from excessive use of pain relief medications, such as \u003ca href=\"https://www.medicalnewstoday.com/articles/drugs-acetaminophen-oral-forms\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/drugs-acetaminophen-oral-forms\" class=\"content-link css-90fpmc\"\u003eacetaminophen (Tylenol)\u003c/a\u003e and \u003ca href=\"https://www.medicalnewstoday.com/articles/opiate-vs-opioid\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/opiate-vs-opioid\" class=\"content-link css-90fpmc\"\u003eopiates\u003c/a\u003e. It typically develops in people who have been taking large doses of pain relievers for at least \u003ca href=\"https://migrainetrust.org/understand-migraine/types-of-migraine/medication-overuse-headache/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003e3 months\u003c/a\u003e."},{"tagName":"p","source":"For someone with a medication overuse headache, the pain is typically dull and constant, occurring on most days. The location of the pain varies from person to person."},{"tagName":"p","source":"Other possible symptoms include:"},{"tagName":"ul","source":"\u003cli\u003enausea\u003c/li\u003e\u003cli\u003evomiting\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/325162\" class=\"content-link css-90fpmc\"\u003estomach pain\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/158634\" class=\"content-link css-90fpmc\"\u003ediarrhea\u003c/a\u003e\u003c/li\u003e\u003cli\u003edisturbed sleep\u003c/li\u003e\u003cli\u003erestlessness\u003c/li\u003e"}]},{"id":"sinus-headache","title":"Sinus headache","isCollapsable":false,"header":["Sinus headache"],"body":[{"tagName":"p","source":"The sinuses are a network of air-filled cavities in the skull. The main sinuses sit inside the forehead, cheekbones, and nasal cavity. A \u003ca href=\"https://www.medicalnewstoday.com/articles/321012\" class=\"content-link css-90fpmc\"\u003esinus headache\u003c/a\u003e is a secondary headache, and the pain affects one or more of these areas. "},{"tagName":"p","source":"Sinus headaches are usually a symptom of a \u003ca href=\"https://www.medicalnewstoday.com/articles/307190\" class=\"content-link css-90fpmc\"\u003esinus infection\u003c/a\u003e, and this type of infection is often bacterial."},{"tagName":"p","source":"Other possible symptoms of a sinus infection \u003ca href=\"https://acaai.org/allergies/allergic-conditions/sinus-infection/\" data-type=\"link\" data-id=\"https://acaai.org/allergies/allergic-conditions/sinus-infection/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003einclude:\u003c/a\u003e"},{"tagName":"ul","source":"\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/325248\" class=\"content-link css-90fpmc\"\u003ea runny nose\u003c/a\u003e\u003c/li\u003e\u003cli\u003egreen nasal discharge\u003c/li\u003e\u003cli\u003etenderness in the area\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/why-do-my-teeth-hurt\" class=\"content-link css-90fpmc\"\u003epainful teeth\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/166636\" class=\"content-link css-90fpmc\"\u003ebad breath\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/220349\" class=\"content-link css-90fpmc\"\u003ecoughing\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/168266\" class=\"content-link css-90fpmc\"\u003ea fever\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/248002\" class=\"content-link css-90fpmc\"\u003efatigue\u003c/a\u003e\u003c/li\u003e"}]},{"id":"post-traumatic-headache","title":"Post-traumatic headache","isCollapsable":false,"header":["Post-traumatic headache"],"body":[{"tagName":"p","source":"This is a secondary headache that occurs in response to head trauma. "},{"tagName":"p","source":"Post-traumatic headaches are the \u003chl-trusted-source source=\"PubMed Central\" rationale=\"Highly respected database from the National Institutes of Health\"\u003e\u003ca href=\"https://pubmed.ncbi.nlm.nih.gov/38568491/\" data-type=\"link\" data-id=\"https://pubmed.ncbi.nlm.nih.gov/38568491/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003emost common\u003c/a\u003e\u003c/hl-trusted-source\u003e acute symptom after a \u003ca href=\"https://www.medicalnewstoday.com/articles/179837\" class=\"content-link css-90fpmc\"\u003etraumatic brain injury\u003c/a\u003e. Experts estimate that around \u003chl-trusted-source source=\"PubMed Central\" rationale=\"Highly respected database from the National Institutes of Health\"\u003e\u003ca href=\"https://pubmed.ncbi.nlm.nih.gov/29757458/\" data-type=\"link\" data-id=\"https://pubmed.ncbi.nlm.nih.gov/29757458/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003e18–58%\u003c/a\u003e\u003c/hl-trusted-source\u003e of people with this type of brain injury experience a post-traumatic headache within the next year. However, the headache usually develops within \u003chl-trusted-source source=\"PubMed Central\" rationale=\"Highly respected database from the National Institutes of Health\"\u003e\u003ca href=\"https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10342432/\" data-type=\"link\" data-id=\"https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10342432/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003e7 days\u003c/a\u003e\u003c/hl-trusted-source\u003e of the injury."},{"tagName":"p","source":"A post-traumatic headache is often mild to moderate, and the pain may be pressing or dull. It frequently occurs in the following locations:"},{"tagName":"ul","source":"\u003cli\u003etemples\u003c/li\u003e\u003cli\u003eforehead\u003c/li\u003e\u003cli\u003eneck \u003c/li\u003e"},{"tagName":"p","source":"Less often, the headache may occur at the back and top of the head and around the eyes."},{"tagName":"p","source":"Other possible symptoms \u003chl-trusted-source source=\"BMC/BioMed Central\" rationale=\"Peer reviewed journal\"\u003e\u003ca href=\"https://thejournalofheadacheandpain.biomedcentral.com/articles/10.1186/s10194-020-01122-5\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003einclude\u003c/a\u003e\u003c/hl-trusted-source\u003e:"},{"tagName":"ul","source":"\u003cli\u003enausea\u003c/li\u003e\u003cli\u003evomiting\u003c/li\u003e\u003cli\u003esensitivity to light and sound\u003c/li\u003e\u003cli\u003eimpaired cognitive function\u003c/li\u003e\u003cli\u003eanxiety\u003c/li\u003e\u003cli\u003edepression\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/165408\" class=\"content-link css-90fpmc\"\u003eurinary incontinence\u003c/a\u003e\u003c/li\u003e"}]},{"id":"underlying-health-conditions","title":"Underlying health conditions","isCollapsable":false,"header":["Underlying health conditions"],"body":[{"tagName":"p","source":"Less commonly, some headaches can be caused by a serious underlying health condition \u003chl-trusted-source source=\"National Institute of Neurological Disorders and Stroke\" rationale=\"Governmental authority\"\u003e\u003ca href=\"https://www.ninds.nih.gov/health-information/disorders/headache\" data-type=\"link\" data-id=\"https://www.ninds.nih.gov/health-information/disorders/headache\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003esuch as\u003c/a\u003e\u003c/hl-trusted-source\u003e: "},{"tagName":"ul","source":"\u003cli\u003ea \u003ca href=\"https://www.medicalnewstoday.com/articles/315625\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/315625\" class=\"content-link css-90fpmc\"\u003ebrain tumor\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/types-of-meningitis\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/types-of-meningitis\" class=\"content-link css-90fpmc\"\u003emeningitis\u003c/a\u003e\u003c/li\u003e\u003cli\u003ea \u003ca href=\"https://www.medicalnewstoday.com/articles/326044\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/326044\" class=\"content-link css-90fpmc\"\u003ebrain aneurysm\u003c/a\u003e (unruptured or ruptured)\u003c/li\u003e\u003cli\u003ea \u003ca href=\"https://www.medicalnewstoday.com/articles/327363\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/327363\" class=\"content-link css-90fpmc\"\u003espinal fluid leak\u003c/a\u003e\u003c/li\u003e\u003cli\u003e\u003ca href=\"https://www.medicalnewstoday.com/articles/7624\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/7624\" class=\"content-link css-90fpmc\"\u003estroke\u003c/a\u003e\u003c/li\u003e"},{"tagName":"p","source":"If a person has a sudden and severe headache that is \u003ca href=\"https://www.nhs.uk/conditions/headaches/\" data-type=\"link\" data-id=\"https://www.nhs.uk/conditions/headaches/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003eaccompanied by\u003c/a\u003e other symptoms such as a head injury, loss of vision, sudden memory problems, or a fever, they should seek urgent care. "},{"tagName":"script","attributes":{"type":"application/ld+json"},"source":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"How can I identify my headache?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A person may be able to identify their headache by the following factors: \n•\tlocation of the pain\n•\twhether it's a throbbing, stabbing, or dull pain\n•\tduration of the headache\n•\taccompanying symptoms\n•\ttriggers\n•\tfrequency\n\"}},{\"@type\":\"Question\",\"name\":\"What kind of headaches should I worry about?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A person should seek immediate medical attention if their headache is sudden and severe and is accompanied by the following symptoms: \n•\ta head injury\n•\tloss of vision\n•\tdrowsiness\n•\tsudden problems with speech or memory\n•\ta fever\n\"}},{\"@type\":\"Question\",\"name\":\"What does a dehydration headache feel like?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A dehydration headache may be felt at the front, back, on one side, or throughout the entire head. Movement or walking often makes a dehydration headache worse or more painful.\"}}]}"}]},{"id":"faq","title":"FAQ","isCollapsable":false,"header":["Frequently asked questions "],"body":[{"tagName":"h3","source":"How can I identify my headache?"},{"tagName":"p","source":"A person \u003chl-trusted-source source=\"National Institute of Neurological Disorders and Stroke\" rationale=\"Governmental authority\"\u003e\u003ca href=\"https://www.ninds.nih.gov/health-information/disorders/headache\" data-type=\"link\" data-id=\"https://www.ninds.nih.gov/health-information/disorders/headache\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003emay be\u003c/a\u003e\u003c/hl-trusted-source\u003e able to identify their headache by the following factors: "},{"tagName":"ul","source":"\u003cli\u003elocation of the pain\u003c/li\u003e\u003cli\u003ewhether it’s a throbbing, stabbing, or dull pain\u003c/li\u003e\u003cli\u003eduration of the headache\u003c/li\u003e\u003cli\u003eaccompanying symptoms\u003c/li\u003e\u003cli\u003etriggers\u003c/li\u003e\u003cli\u003efrequency\u003c/li\u003e"},{"tagName":"h3","source":"What kind of headaches should I worry about?"},{"tagName":"p","source":"A person should seek immediate medical attention if their headache is sudden and severe and is accompanied by the following \u003ca href=\"https://www.nhs.uk/conditions/headaches/\" data-type=\"link\" data-id=\"https://www.nhs.uk/conditions/headaches/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003esymptoms\u003c/a\u003e: "},{"tagName":"ul","source":"\u003cli\u003ea head injury\u003c/li\u003e\u003cli\u003eloss of vision\u003c/li\u003e\u003cli\u003edrowsiness\u003c/li\u003e\u003cli\u003esudden problems with speech or memory\u003c/li\u003e\u003cli\u003ea fever\u003c/li\u003e"},{"tagName":"h3","source":"What does a dehydration headache feel like?"},{"tagName":"p","source":"A dehydration headache \u003ca href=\"https://blackdoctor.org/headache-location-meaning/\" data-type=\"link\" data-id=\"https://blackdoctor.org/headache-location-meaning/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"content-link css-90fpmc\"\u003emay be\u003c/a\u003e felt at the front, back, on one side, or throughout the entire head. Movement or walking often makes a \u003ca href=\"https://www.medicalnewstoday.com/articles/317511\" data-type=\"link\" data-id=\"https://www.medicalnewstoday.com/articles/317511\" class=\"content-link css-90fpmc\"\u003edehydration headache\u003c/a\u003e worse or more painful."}]},{"id":"summary","title":"Summary","isCollapsable":false,"header":["Summary"],"body":[{"tagName":"p","source":"Different types of headaches can cause different types of pain. Headache pain also varies in severity, duration, and frequency. "},{"tagName":"p","source":"There are two broad categories of headaches: primary and secondary, depending on whether the headache is caused by an underlying problem or not."},{"tagName":"p","source":"Anyone with new or more frequent headaches should contact a healthcare professional. It is especially important to receive medical care for any headache that occurs with concerning symptoms or is severe or otherwise keeps a person from their daily activities."}]}],"hasAffiliateLinks":false,"affiliates":[],"isDisclaimer":false,"isOwnedAndOperatedPresent":false,"propsFor":{"articleResources":[{"displayLink":"pubmed.ncbi.nlm.nih.gov/34128449/","link":"https://pubmed.ncbi.nlm.nih.gov/34128449/","title":{"tagName":"span","source":"Bentivegna E, et al. (2021). Recent advancements in tension-type headache: a narrative review."}},{"displayLink":"migrainetrust.org/understand-migraine/types-of-migraine/other-headache-disorders/cluster-headache/","link":"https://migrainetrust.org/understand-migraine/types-of-migraine/other-headache-disorders/cluster-headache/","title":{"tagName":"span","source":"Cluster headache. (n.d.)."}},{"displayLink":"uhsussex.nhs.uk/resources/dietary-advice-for-migraine-2/","link":"https://www.uhsussex.nhs.uk/resources/dietary-advice-for-migraine-2/","title":{"tagName":"span","source":"Dietary advice for migraine. (2023)."}},{"displayLink":"ninds.nih.gov/health-information/disorders/headache","link":"https://www.ninds.nih.gov/health-information/disorders/headache","title":{"tagName":"span","source":"Headache. (2024)."}},{"displayLink":"blackdoctor.org/headache-location-meaning/","link":"https://blackdoctor.org/headache-location-meaning/","title":{"tagName":"span","source":"Headache locations: What do they mean? (n.d.)."}},{"displayLink":"nhs.uk/conditions/headaches/","link":"https://www.nhs.uk/conditions/headaches/","title":{"tagName":"span","source":"Headaches. (2024)."}},{"displayLink":"pubmed.ncbi.nlm.nih.gov/29757458/","link":"https://pubmed.ncbi.nlm.nih.gov/29757458/","title":{"tagName":"span","source":"Kamins J, et al. (2018). Posttraumatic headache: Basic mechanisms and therapeutic targets."}},{"displayLink":"ncbi.nlm.nih.gov/books/NBK544241/","link":"https://www.ncbi.nlm.nih.gov/books/NBK544241/","title":{"tagName":"span","source":"Kandel SA, et al. (2023). Cluster headache."}},{"displayLink":"ncbi.nlm.nih.gov/books/NBK554611/","link":"https://www.ncbi.nlm.nih.gov/books/NBK554611/","title":{"tagName":"span","source":"Kikkeri NS, et al. (2024). Migraine with aura."}},{"displayLink":"thejournalofheadacheandpain.biomedcentral.com/articles/10.1186/s10194-020-01122-5","link":"https://thejournalofheadacheandpain.biomedcentral.com/articles/10.1186/s10194-020-01122-5","title":{"tagName":"span","source":"Labastida-Ram\u0026iacute;rez A, et al. (2020). Persistent post-traumatic headache: a migrainous loop or not? The clinical evidence."}},{"displayLink":"ncbi.nlm.nih.gov/pmc/articles/PMC10342432/","link":"https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10342432/","title":{"tagName":"span","source":"Mavroudis I, et al. (2023). Post-traumatic headache: A review of prevalence, clinical features, risk factors, and treatment strategies."}},{"displayLink":"migrainetrust.org/understand-migraine/types-of-migraine/medication-overuse-headache/","link":"https://migrainetrust.org/understand-migraine/types-of-migraine/medication-overuse-headache/","title":{"tagName":"span","source":"Medication overuse headache. (n.d.)."}},{"displayLink":"ninds.nih.gov/health-information/disorders/migraine","link":"https://www.ninds.nih.gov/health-information/disorders/migraine","title":{"tagName":"span","source":"Migraine. (2024)."}},{"displayLink":"americanmigrainefoundation.org/migraine-101/","link":"https://americanmigrainefoundation.org/migraine-101/","title":{"tagName":"span","source":"Migraine 101: What you should know. (n.d.)."}},{"displayLink":"who.int/news-room/fact-sheets/detail/headache-disorders","link":"https://www.who.int/news-room/fact-sheets/detail/headache-disorders","title":{"tagName":"span","source":"Migraine and other headache disorders. (2024)."}},{"displayLink":"ncbi.nlm.nih.gov/pmc/articles/PMC10360340/","link":"https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10360340/","title":{"tagName":"span","source":"Onan D, et al. (2023). Debate: differences and similarities between tension-type headache and migraine."}},{"displayLink":"cdc.gov/mmwr/volumes/72/wr/mm7222a6.htm","link":"https://www.cdc.gov/mmwr/volumes/72/wr/mm7222a6.htm","title":{"tagName":"span","source":"QuickStats: Percentage* of adults aged \u0026ge;18 years who have been bothered a lot by headache or migraine in the past 3 months,\u0026dagger; by sex and age group \u0026mdash; National health interview survey, 2021. (2023)."}},{"displayLink":"pubmed.ncbi.nlm.nih.gov/38568491/","link":"https://pubmed.ncbi.nlm.nih.gov/38568491/","title":{"tagName":"span","source":"Schwedt TJ. (2024). Posttraumatic headache."}},{"displayLink":"acaai.org/allergies/allergic-conditions/sinus-infection/","link":"https://acaai.org/allergies/allergic-conditions/sinus-infection/","title":{"tagName":"span","source":"Sinus infection. (n.d.)."}},{"displayLink":"americanmigrainefoundation.org/resource-library/tension-type-headache/","link":"https://americanmigrainefoundation.org/resource-library/tension-type-headache/","title":{"tagName":"span","source":"Tension-type headache: Symptoms, types and treatments. (2023)."}},{"displayLink":"ihs-headache.org/wp-content/uploads/2020/05/ICHD-3-Pocket-version.pdf","link":"https://ihs-headache.org/wp-content/uploads/2020/05/ICHD-3-Pocket-version.pdf","title":{"tagName":"span","source":"The international classification of headache disorders 3rd edition. (2018)."}}],"byline":{"authors":[{"id":4026,"name":{"display":"Sasha Santhakumar","first":"Sasha","last":"Santhakumar"},"type":{"value":"author","label":"Author"},"nid":"","specialties":[],"guestTitle":"","bio":{"text":""},"avatar":{"title":"","src":"","alt":""}}],"medicalReviewers":[{"id":333,"name":{"display":"Heidi Moawad, M.D.","first":"Heidi","last":"Moawad, MD"},"userLogin":"heidimoawad","links":{"website":"http://www.nonclinicaldoctors.com/","facebook":"","linkedin":"https://www.linkedin.com/in/heidi-moawad-md-17879aa/","twitter":"","instagram":"","tiktok":""},"link":"/reviewers/heidi-moawad-md","type":{"value":"medical_reviewer","label":"Medical Advisor"},"nid":"159928","specialties":[],"guestTitle":"","bio":{"text":"\u003cspan style=\"font-weight: 400;\"\u003eDr. Heidi Moawad is a neurologist and teaches at Case Western Reserve University School of Medicine in Cleveland, Ohio. She serves on the editorial board of Neurology Clinical Practice and is a reviewer for Neurology.\u003c/span\u003e\r\n\r\n\u003cstrong\u003eEducation\u003c/strong\u003e\r\n\u003cul\u003e\r\n \t\u003cli style=\"font-weight: 400;\"\u003e\u003cspan style=\"font-weight: 400;\"\u003eCase Western Reserve University School of Medicine, MD\u003c/span\u003e\u003c/li\u003e\r\n\u003c/ul\u003e\r\n\u003cstrong\u003eCertifications\u003c/strong\u003e\r\n\u003cul\u003e\r\n \t\u003cli style=\"font-weight: 400;\"\u003e\u003cspan style=\"font-weight: 400;\"\u003eBoard of Medical Examiners\u003c/span\u003e\u003c/li\u003e\r\n\u003c/ul\u003e\r\n\u003cstrong\u003eProfessional Accomplishments\u003c/strong\u003e\r\n\u003cul\u003e\r\n \t\u003cli style=\"font-weight: 400;\"\u003e\u003cspan style=\"font-weight: 400;\"\u003eAssociate editor, Neurology, Humanities section \u003c/span\u003e\u003c/li\u003e\r\n \t\u003cli style=\"font-weight: 400;\"\u003e\u003cspan style=\"font-weight: 400;\"\u003ePast editor-in-chief of Neurology Times\u003c/span\u003e\u003c/li\u003e\r\n\u003c/ul\u003e\r\n\u003cstrong\u003eAffiliations\u003c/strong\u003e\r\n\u003cul\u003e\r\n \t\u003cli style=\"font-weight: 400;\"\u003e\u003ca href=\"https://www.aan.com/\"\u003e\u003cspan style=\"font-weight: 400;\"\u003eAmerican Academy of Neurology (AAN)\u003c/span\u003e\u003c/a\u003e\u003c/li\u003e\r\n\u003c/ul\u003e"},"avatar":{"title":"","width":500,"height":500,"src":"https://post.medicalnewstoday.com/wp-content/uploads/2022/01/Heidi-Moawad-500x500-Bio.png","alt":""}}],"id":"mnt-3431412","updateReason":["The article was updated with additional information to ensure it provides our readers with a comprehensive overview of the topic.","The article was updated with current verified sources and links to relevant information."],"editor":"Chloe Szilagyi","factCheckedBy":"","factCheckers":[],"articleHistory":{"2021-10-29":{"updateReason":[],"authors":"Sasha Santhakumar","editor":"MNT Demand Team","copyEditor":"Gianna D'Emilio","medicallyReviewedBy":"Deena Kuruvilla, MD"},"2023-10-10":{"updateReason":["The article was updated with additional information to ensure it provides our readers with a comprehensive overview of the topic."],"authors":"Sasha Santhakumar","editor":"MNT Demand Team"},"2024-08-09":{"updateReason":["The article was updated with additional information to ensure it provides our readers with a comprehensive overview of the topic.","The article was updated with current verified sources and links to relevant information."],"authors":"Sasha Santhakumar","editor":"Chloe Szilagyi","copyEditor":"Copy Editors","medicallyReviewedBy":"Heidi Moawad, MD"}},"articleDates":{"factChecked":{"date":null,"display":""},"medicallyReviewed":{"date":1723197965,"display":"August 9, 2024"},"published":{"date":1635469200,"display":"October 29, 2021"},"lastUpdates":{"date":1723197964,"display":"August 9, 2024"},"modified":{"date":1723201612,"display":"August 9, 2024"}},"type":"healthfeature","language":"en"},"readNext":{"items":[{"title":["What are stretches for headaches?"],"text":["People can use neck, shoulder, and back stretches to relieve tension. This can help with headaches. Learn more."],"link":"/articles/stretches-for-headaches","imageAlt":"What are stretches for headaches?","thumbnail":"https://media.post.rvohealth.io/wp-content/uploads/sites/3/2023/04/man_stretching_neck_at_home_732x549-thumbnail-732x549.jpg","medicallyReviewedBy":{"reviewerName":"Kerry Boyle D.Ac., M.S., L.Ac., Dipl. Ac., CYT","reviewerImage":{"path":"https://media.post.rvohealth.io/wp-content/uploads/sites/3/2021/04/Kerry_Boyle_500x500_Med_Reviewer_Photos_v2.png","width":200,"height":200,"altText":""}},"isNutrition":false,"authors":[{"id":6767,"name":{"display":"Jen Colwell","first":"Jen","last":"Colwell"},"userLogin":"jcolwell","links":{"website":"","facebook":"","linkedin":"","twitter":"","instagram":"","tiktok":""},"type":{"value":"author","label":"Author"},"nid":"","specialties":[],"guestTitle":"","bio":{"text":""},"avatar":{"title":"","src":"","alt":""}}],"reviewedByHeader":"Medically reviewed by","language":"en"},{"title":["What is headache hygiene?"],"text":["Headache hygiene can reduce the amount of headaches, as well as the severity of them, through lifestyle changes and avoiding triggers."],"link":"/articles/headache-hygiene","imageAlt":"What is headache hygiene?","thumbnail":"https://media.post.rvohealth.io/wp-content/uploads/sites/3/2023/07/standing-bamboo-headache-hygiene-732x549-thumbnail-732x549.jpg","medicallyReviewedBy":{"reviewerName":"Deena Kuruvilla, MD","reviewerImage":{"path":"https://post.medicalnewstoday.com/wp-content/uploads/2022/01/Deena-Kuruvilla-500x500-Bio.png","width":200,"height":200,"altText":""},"specialties":[]},"isNutrition":false,"authors":[{"id":1552,"name":{"display":"Zia Sherrell, MPH","first":"Zia","last":"Sherrell, MPH"},"userLogin":"zsherrell","links":{"website":"http://www.premiumhealthcontent.com","facebook":"https://www.facebook.com/ziahealthwriter","linkedin":"https://www.linkedin.com/in/freelance-healthcare-writer/","twitter":"/ziahealthwriter","instagram":"https://www.instagram.com/ziahealthwriter","tiktok":""},"link":"/authors/zia-sherrell","type":{"value":"expert","label":"Expert"},"nid":"","specialties":[],"guestTitle":"","bio":{"text":"\u003cp data-pm-slice=\"1 1 []\"\u003eZia Sherrell is a \u003ca class=\"ProsemirrorEditor-link\" href=\"https://www.premiumhealthcontent.com/common-faq-to-a-health-copywriter\"\u003ehealth copywriter\u003c/a\u003e and \u003ca class=\"ProsemirrorEditor-link\" href=\"https://www.premiumhealthcontent.com/about-your-healthcare-copywriter\"\u003edigital health journalist\u003c/a\u003e with over a decade of experience covering diverse topics from public health to medical cannabis, nutrition, and biomedical science. Her mission is to empower and educate people by bringing health matters to life with engaging, evidence-based writing. When she’s not writing, Zia enjoys traveling and chasing after her dogs.\u003c/p\u003e"},"avatar":{"title":"","width":1380,"height":1449,"src":"https://post.medicalnewstoday.com/wp-content/uploads/sites/3/2020/06/cropped.jpg","alt":""}}],"reviewedByHeader":"Medically reviewed by","language":"en"},{"title":["What causes a headache after Botox?"],"text":["Headache is a common side effect of Botox (onabotulinumtoxinA). Learn why it happens, what it feels like, how long it lasts, how to manage it, and…"],"link":"/articles/drugs-headache-after-botox","imageAlt":"What causes a headache after Botox?","thumbnail":"https://media.post.rvohealth.io/wp-content/uploads/sites/3/2025/03/Headache-Botox-GettyImages-1330885447-Thumb.jpg","isNutrition":false,"authors":[{"id":5363,"name":{"display":"Leah Persaud, PhD","first":"Leah","last":"Persaud, PhD"},"userLogin":"lpersaud","links":{"website":"","facebook":"","linkedin":"","twitter":"","instagram":"","tiktok":""},"link":"/authors/leah-persaud","type":{"value":"author","label":"Author"},"nid":"","specialties":[],"guestTitle":"","bio":{"text":"\u003cp data-pm-slice=\"1 1 []\"\u003eLeah Persaud, PhD (she/her), is a medical communications professional specializing in consumer drug information. With a doctorate in Molecular, Cellular, and Developmental Biology, Dr. Persaud has a strong background in scientific research with contributions to anticancer therapeutics. She has received multiple honors, including an excellence in teaching award, and is a published author in peer-reviewed journals. Connect with her on \u003ca href=\"https://www.linkedin.com/in/leahpersaud\"\u003eLinkedIn\u003c/a\u003e.\u003c/p\u003e"},"avatar":{"title":"","width":500,"height":500,"src":"https://post.medicalnewstoday.com/wp-content/uploads/2025/07/Leah-Persaud-500x500-Bio.png","alt":"Leah Persaud"}}],"reviewedByHeader":"Medically reviewed by","language":"en"},{"title":["Can newborns get headaches?"],"text":["Newborns can experience headaches. Diagnosing them may be an issue, since they cannot communicate. However, they could be reflect in feeding issues…"],"link":"/articles/can-newborns-get-headaches","imageAlt":"Can newborns get headaches?","thumbnail":"https://media.post.rvohealth.io/wp-content/uploads/sites/3/2024/07/newborns-headaches-GettyImages-108178114-Thumb.jpg","medicallyReviewedBy":{"reviewerName":"Karen Gill, M.D.","reviewerImage":{"path":"https://post.medicalnewstoday.com/wp-content/uploads/2022/01/Karen-Richardson-Gill-500x500-Bio.png","width":200,"height":200,"altText":""},"specialties":["pediatrics"]},"isNutrition":false,"authors":[{"id":1552,"name":{"display":"Zia Sherrell, MPH","first":"Zia","last":"Sherrell, MPH"},"userLogin":"zsherrell","links":{"website":"http://www.premiumhealthcontent.com","facebook":"https://www.facebook.com/ziahealthwriter","linkedin":"https://www.linkedin.com/in/freelance-healthcare-writer/","twitter":"/ziahealthwriter","instagram":"https://www.instagram.com/ziahealthwriter","tiktok":""},"link":"/authors/zia-sherrell","type":{"value":"expert","label":"Expert"},"nid":"","specialties":[],"guestTitle":"","bio":{"text":"\u003cp data-pm-slice=\"1 1 []\"\u003eZia Sherrell is a \u003ca class=\"ProsemirrorEditor-link\" href=\"https://www.premiumhealthcontent.com/common-faq-to-a-health-copywriter\"\u003ehealth copywriter\u003c/a\u003e and \u003ca class=\"ProsemirrorEditor-link\" href=\"https://www.premiumhealthcontent.com/about-your-healthcare-copywriter\"\u003edigital health journalist\u003c/a\u003e with over a decade of experience covering diverse topics from public health to medical cannabis, nutrition, and biomedical science. Her mission is to empower and educate people by bringing health matters to life with engaging, evidence-based writing. When she’s not writing, Zia enjoys traveling and chasing after her dogs.\u003c/p\u003e"},"avatar":{"title":"","width":1380,"height":1449,"src":"https://post.medicalnewstoday.com/wp-content/uploads/sites/3/2020/06/cropped.jpg","alt":""}}],"reviewedByHeader":"Medically reviewed by","language":"en"},{"title":["What to know about jet lag and headaches"],"text":["Jet lag can cause a headache that may resolve as a person adapts to the new time zone. Learn about other symptoms and when to seek help."],"link":"/articles/jet-lag-headache","imageAlt":"What to know about jet lag and headaches","thumbnail":"https://media.post.rvohealth.io/wp-content/uploads/sites/3/2024/07/jet-lag-GettyImages-2165552504-Thumb.jpg","medicallyReviewedBy":{"reviewerName":"Meredith Goodwin, MD, FAAFP","reviewerImage":{"path":"https://media.post.rvohealth.io/wp-content/uploads/sites/3/2022/03/Meredith-Goodwin-500x500-Bio.png","width":200,"height":200,"altText":""},"specialties":[]},"isNutrition":false,"authors":[{"id":1000,"name":{"display":"Charlotte Lillis","first":"Charlotte","last":"Lillis"},"userLogin":"clillis","links":{"website":"","facebook":"","linkedin":"","twitter":"","instagram":"","tiktok":""},"link":"/authors/charlotte-lillis","type":{"value":"author","label":"Author"},"nid":"","specialties":[],"guestTitle":"","bio":{"text":"Charlotte is a freelance writer and editor. She has a bachelor's degree in psychology with cognitive science from the University of Sussex in the U.K. Charlotte has worked as a research scientist investigating human and animal behavior in four different research groups across the U.K. She has now taken up writing full-time. Aside from communicating science, Charlotte enjoys composing music and makes stage props for television and theater productions.\r\n\r\n\u003cstrong\u003eTo keep up with Charlotte, follow her on \u003ca class=\"\u0026quot;button_followrel=\u0026quot;noopener\" href=\"//twitter.com/CV_Lillis\u0026quot;\" target=\"\u0026quot;_blanktitle=\u0026quot;Follow\"\u003eTwitter\u003c/a\u003e.\u003c/strong\u003e"},"avatar":{"title":"","width":500,"height":500,"src":"https://post.medicalnewstoday.com/wp-content/uploads/sites/3/2020/06/500x500_Charlotte_Lillis.png","alt":""}}],"reviewedByHeader":"Medically reviewed by","language":"en"}],"language":"en"},"isCorp":false,"isReference":false,"isPremiumVideo":false,"isStandaloneVideo":false,"isStandaloneRecipe":false,"schemaObj":{"@context":"https://schema.org","publisher":{"@type":"Organization","name":"Medical News Today","logo":{"@type":"ImageObject","url":"https://cdn-prod.medicalnewstoday.com/structure/images/logo/logo-2017-640-60.png"}},"@type":"MedicalWebPage","headline":"Types of headache by location and symptoms","description":"Experts classify headaches by the type, location, and frequency of pain, as well as by the various causes. Learn more and find a helpful chart here.","keywords":"headache chart","author":{"@type":"Person","name":"Sasha Santhakumar"},"lastReviewed":"2024-08-09T10:06:05Z","url":"https://www.medicalnewstoday.com/articles/headache-chart","datePublished":"2021-10-29T01:00:00Z","dateModified":"2024-08-09T10:06:04Z","articleSection":"Headache / Migraine,Neurology / Neuroscience,Pain / Anesthetics","correction":{"@type":"CorrectionComment","text":"The article was updated with additional information to ensure it provides our readers with a comprehensive overview of the topic. The art