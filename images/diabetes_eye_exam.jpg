    <script>
  class PageContext {
    static #instance;
    #data = {
  "country" : "GB",
  "language" : "en",
  "locale" : "en_GB",
  "auth" : {
    "enabled" : false
  }
};

    constructor() {
      if (PageContext.#instance ) return PageContext.#instance;
      PageContext.#instance = this;
      Object.freeze(this.#data);
    }

    #appendQueryToUrl(
      given_url,
      query=new URLSearchParams(window.location.search)
    ) {
      const url = new URL(given_url);
      query.forEach(
        (value, param) => url.searchParams.append(param, value)
      );
      return url;
    }

    #getLoginUrlAem(keepQuery) {
      const url = new URL(this.#data.auth.loginUrl.url);
      return keepQuery ? this.#appendQueryToUrl(url) : url;
    }

    #getLoginUrlCustomAuth(keepQuery) {
      const pattern = this.#data.auth.loginUrl.pattern;
      let returnUrl = this.#data.auth.loginUrl.returnUrl;
      if ( keepQuery ) returnUrl = this.#appendQueryToUrl(returnUrl);

      return new URL(
        pattern.replace(
          "{login_return_url}",
          encodeURIComponent(returnUrl)
        )
      );
   }

    #getLogoutUrl(keepQuery=false) {
      if ( !this.#data.auth.enabled ) return undefined;
      return keepQuery ? this.#appendQueryToUrl(this.#data.auth.logoutUrl) : new URL(this.#data.auth.logoutUrl);
  }

    #getLoginUrl(keepQuery=true) {
      if ( !this.#data.auth.enabled ) return undefined;

      if ( this.#data.auth.type == "AEM" ) {
        return this.#getLoginUrlAem(keepQuery);
      }
      if ( this.#data.auth.type == "CUSTOM_AUTH_HANDLER" ) {
        return this.#getLoginUrlCustomAuth(keepQuery);
      }
    }
    get country() { return this.#data.country }
    get language() { return this.#data.language }
    get locale() { return this.#data.locale }
    get logoutUrl() {return this.#getLogoutUrl()}
    get loginUrl() {return this.#getLoginUrl()}
  }

  const pageContext = new PageContext();
  Object.freeze(pageContext);
</script>
 
