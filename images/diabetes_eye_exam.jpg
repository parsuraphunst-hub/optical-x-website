               outline: 1px solid #000000;
               outline-offset: 1px;
            }/**
* Preference center CSS for One Trust
*/

/* Hide */
body #onetrust-pc-sdk .pc-logo-container,
body #onetrust-pc-sdk .ot-pc-logo,
#onetrust-pc-sdk .ot-pc-footer-logo {
  display: none;
}

/* Typography */

#onetrust-pc-sdk {
  font-family: inherit;
}

#onetrust-pc-sdk .ot-btn-container button,
#onetrust-pc-sdk #accept-recommended-btn-handler {
  font-weight: normal;
  font-size: 1rem;
}

/* Resets */

#onetrust-pc-sdk #ot-pc-desc a.inline-link {
  margin-left: 0;
}
