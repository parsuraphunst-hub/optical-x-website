            @media only screen and (min-width: 992px) {
#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy table { 
        max-width: 100%;
        margin-left: 0;
}
#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy section { 
        max-width: 100%;
}
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy #cookie-policy-title { 
     font-style: normal;
     font-weight: 700;
     color: #262626;
     font-size: 1.5rem;
     line-height: 1.33333;
     letter-spacing: 0.03125rem;
     margin-top: 1.25rem;
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy h5, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy h6, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy li, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy p, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy a, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy span, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy td, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy #cookie-policy-description { 
      color: #262626; 
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy .ot-sdk-cookie-policy-title  {
      margin-bottom: 2rem
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy #cookie-policy-description, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy .ot-sdk-cookie-policy-group-desc, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy .ot-table-header, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy a, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy span, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy td { 
       font-size: inherit;
       color: #262626;
}
#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy #cookie-policy-description, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy .ot-sdk-cookie-policy-group-desc, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy a, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy span, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy td { 
       font-weight: 300;
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy .ot-sdk-cookie-policy-group, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy .ot-table-header { 
      color: #262626; 
      font-size: 1.14285714rem;
       line-height: 1.25;
       font-style: normal;
       font-weight: 700;
       margin-bottom: 1rem
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy table tr:hover { 
      background-color: #F0F0F0;
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy a, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy a:hover { 
      background: unset;
}

#ot-sdk-cookie-policy p { 
      margin-bottom: 3rem;
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy table { 
      border-left: none;
      border-right: none;
       border-top: 1px solid #262626;
       border-radius: 0px;
       border-bottom: 1px solid #262626;
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy table th, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy table td { 
        border-left: none;
        border-right: none;
        border-bottom: 1px solid #262626;
        padding-top: 1rem;
        padding-bottom: 1rem;
        overflow-wrap: anywhere;
        word-break: break-word;
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy #cookie-policy-description { 
         margin-bottom: 4rem;        
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy section { 
    margin-bottom: 3rem;
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy #cookie-policy-description, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy .ot-sdk-cookie-policy-group-desc, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy a, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy span, #ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy td { 
     color: #262626;
}

#ot-sdk-cookie-policy { 
     font-size: inherit;
}

#ot-sdk-cookie-policy-v2.ot-sdk-cookie-policy { 
    font-size: inherit;
}
